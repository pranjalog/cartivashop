# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# Shopify Admin API (used to create orders after a verified payment)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxx
# Optional, defaults to 2024-10
# SHOPIFY_API_VERSION=2024-10

# Shopify OAuth (only needed to OBTAIN SHOPIFY_ADMIN_API_TOKEN via /api/shopify/install)
SHOPIFY_API_KEY=your_app_client_id
SHOPIFY_API_SECRET=shpss_xxx
# Optional overrides
# SHOPIFY_SCOPES=write_orders,read_orders
# SHOPIFY_APP_URL=https://your-app-domain.com
